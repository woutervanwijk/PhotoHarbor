{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kei PhotoSync",
  "version": "0.1.0",
  "identifier": "com.kei.photosync",
  "build": {
    "frontendDist": "../"
  },
  "app": {
    "windows": [
      {
        "title": "Kei PhotoSync",
        "width": 960,
        "height": 640,
        "minWidth": 800,
        "minHeight": 520,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png"],
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  }
}
