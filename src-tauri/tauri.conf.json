{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kei PhotoSync",
  "version": "0.1.0",
  "identifier": "com.kei.photosync",
  "build": {
    "beforeDevCommand": "npm run prepare-sidecar && npm run vite:dev",
    "beforeBuildCommand": "npm run prepare-sidecar && npm run vite:build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Kei PhotoSync",
        "width": 960,
        "height": 640,
        "minWidth": 800,
        "minHeight": 520,
        "resizable": true,
        "fullscreen": false,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/**", "/Volumes/**", "/media/**", "/mnt/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico", "icons/icon.icns", "icons/icon.png", "icons/32x32.png", "icons/64x64.png", "icons/128x128.png", "icons/128x128@2x.png"],
    "externalBin": ["binaries/kei"],
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  }
}
